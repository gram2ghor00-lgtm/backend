# ============================================================
# Gram2Ghor Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git (it's in .gitignore).
# For cPanel production: paste these into Node.js Selector
# "Environment Variables" UI — do NOT upload the .env file.
# ============================================================

# --- Server ---
# Local dev port. cPanel/Passenger sets its own PORT and ignores this.
PORT=8080

# Frontend origin for CORS. No trailing slash.
# Local:   http://localhost:3000
# Vercel:  https://gram2ghor.com   (or https://gram2ghor.vercel.app for previews)
FRONTEND_URL=http://localhost:3000

# --- Database (MongoDB Atlas) ---
# Format: mongodb+srv://USER:PASSWORD@HOST/DB_NAME?options
# The /gram2ghor part is the database name — Atlas creates it on first write.
MONGODB_URI=mongodb+srv://tohasprotrade_db_user:REPLACE_WITH_PASSWORD@cluster0.tjs4b8q.mongodb.net/gram2ghor?retryWrites=true&w=majority&appName=Cluster0

# --- Auth ---
# Long random string. Generate with:  openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Comma-separated emails allowed to log in as admin (lowercase, no spaces).
ADMIN_EMAILS=you@example.com,coadmin@example.com

# --- Cloudinary (image storage) ---
# Get from https://console.cloudinary.com/console (Product Environment Credentials)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Email (Brevo / Sendinblue transactional API) ---
# Get from https://app.brevo.com/settings/keys/api
API_KEY=xkeysib-REPLACE_WITH_BREVO_API_KEY
MAIL_FROM_NAME=Gram2Ghor
MAIL_FROM_ADDRESS=noreply@gram2ghor.com
